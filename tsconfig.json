{
  "compilerOptions": {
    /* Módulos Modernos */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    
    /* Strict Type-Checking */
    "strict": true,
    "skipLibCheck": true,
    
    /* Rutas */
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*"],
  "ts-node": {
    "esm": true
  }
}